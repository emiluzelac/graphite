        "light": {
          "background": "oklch(0.985 0.004 295)",
          "foreground": "oklch(0.21 0.016 295)",
          "card": "oklch(1 0 0)",
          "card-foreground": "oklch(0.21 0.016 295)",
          "popover": "oklch(1 0 0)",
          "popover-foreground": "oklch(0.21 0.016 295)",
